# ─────────────────────────────────────────────────────────────────────────────
# Hemicycle environment configuration
# Copy this file to `.env.local` and fill in values. NEVER commit real keys.
# The seating chart works with NONE of these set — they only unlock vote data.
# ─────────────────────────────────────────────────────────────────────────────

# Free Congress.gov API key — get one at https://api.data.gov/signup/
# Used by the Vite dev proxy (and by the serverless proxy in production) to
# authenticate Congress.gov requests. In the dev proxy this stays server-side.
CONGRESS_API_KEY=

# OPTIONAL fallback for static hosting WITHOUT a proxy.
# WARNING: any VITE_-prefixed variable is embedded in the public client bundle.
# Only use this for throwaway/demo deploys; prefer the proxy + CONGRESS_API_KEY.
# When unset (recommended), the app calls the same-origin /api/* proxy paths.
VITE_CONGRESS_API_KEY=

# OPTIONAL: absolute base URL of a deployed serverless proxy, e.g.
# https://hemicycle-proxy.example.workers.dev
# When unset, the app uses the same-origin relative paths /api/congress and
# /api/senate (served by the Vite dev proxy in development).
VITE_API_BASE=

# OPTIONAL: render the chart from bundled fixtures instead of the live roster.
# Useful for offline UI development. Set to "1" to enable.
VITE_USE_FIXTURES=

# OPTIONAL: base path for the built site (e.g. "/hemicycle/" for GitHub Pages
# project sites). Defaults to "/".
VITE_BASE_PATH=
